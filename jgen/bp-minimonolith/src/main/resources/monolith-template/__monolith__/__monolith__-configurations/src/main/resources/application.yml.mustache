
chenile:
  security:
    client:
      id: "authz-servlet"
      secret: "secret"
    keycloak:
      host: "http://localhost:8180"
      port: 8180
      base:
        realm: quickstart

spring:
  application:
    name: {{monolith}}
{{#enableMCP}}
  ai:
    mcp:
      server:
        enabled: true
        name: {{monolith}}
        type: SYNC
        version: {{monolithVersion}}
        protocol: STREAMABLE
        instructions: "This server exposes MCP tools from the {{monolith}} mini monolith"
        capabilities:
          tool: true
          resource: true
          prompt: true
          completion: true
        streamable-http:
          mcp-endpoint: /mcp
{{/enableMCP}}
  security:
    oauth2:
      resourceserver:
        jwt:
          jwk-set-uri: http://localhost:8180/realms/#tenantId#/protocol/openid-connect/certs

server:
  banner:
    location: classpath:banner.txt
logging:
  level:
    org:
      chenile:
        security: DEBUG
